<Window x:Class="Wiper.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Wiper.wpf.ViewModels"
        xmlns:conv="clr-namespace:Wiper.wpf.Converters"
        Title="Wiper - wipes bin and obj folders" 
        Height="850" 
        Width="655" 
        MinHeight="600" 
        MinWidth="350"
        Background="#F0F0F0"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <StackPanel>
                <!--<Image Source="Resources/Images/wiper-logo.png" Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,10"/>-->
                <TextBlock Text="Solution Path (.sln)" FontWeight="Bold" Margin="0,0,0,5"/>
                <DockPanel>
                    <Button Content="Skanna mappar" 
                            Command="{Binding ScanCommand}" 
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Padding="15,5" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                    <TextBox Text="{Binding Settings.SolutionPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Inkludera: " VerticalAlignment="Center" FontWeight="Bold"/>
                    <ItemsControl ItemsSource="{Binding Settings.FolderTypeOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" Margin="10,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="Mappar hittade">
            <ListView ItemsSource="{Binding FolderList.Folders}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Val">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Projekt" DisplayMemberBinding="{Binding ProjectName}" Width="150"/>
                        <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding Name}" Width="60"/>
                        <GridViewColumn Header="Storlek" DisplayMemberBinding="{Binding SizeDisplay}" Width="80"/>
                        <GridViewColumn Header="Sökväg" DisplayMemberBinding="{Binding FullPath}" Width="300"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="Transparent" Margin="0,5"/>

        <DockPanel Grid.Row="3" Margin="0,5,0,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="LOGG" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Button Content="Kopiera allt" 
                Command="{Binding LogVM.CopyLogsCommand}" 
                Padding="10,2" Margin="0,0,5,0"
                Background="#E0E0E0" FontSize="11"/>
                <Button Content="Rensa logg" 
                Command="{Binding LogVM.ClearLogsCommand}" 
                Padding="10,2"
                Background="#FFE0E0" FontSize="11"/>
            </StackPanel>

            <Grid Background="#1E1E1E">
                <Image Source="Resources/Images/wiper-white.png" 
               Opacity="0.1" 
               Width="150" 
               Height="150" 
               VerticalAlignment="Center" 
               HorizontalAlignment="Center"
               Stretch="Uniform"
               IsHitTestVisible="False"/>

                <ListBox ItemsSource="{Binding LogVM.Logs}" 
                 Background="Transparent" 
                 Foreground="LightGreen" 
                 FontFamily="Consolas" 
                 BorderThickness="0"/>
            </Grid>
        </DockPanel>

        <StatusBar Grid.Row="4" Background="Transparent" Margin="0,10,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding Status}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1">
                <CheckBox Content="Dry Run (Simulera)" IsChecked="{Binding IsDryRun}" Margin="10,0"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="2" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total vinst: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding FolderList.TotalSizeDisplay}" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem Grid.Column="3">
                <Button Content="KÖR RENSNING" Command="{Binding CleanCommand}" 
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Background="#007ACC" Foreground="White" FontWeight="Bold" Padding="20,5"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Grid.RowSpan="5" Background="#88FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
        </Grid>
    </Grid>
</Window>