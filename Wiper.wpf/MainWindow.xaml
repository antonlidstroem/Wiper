<Window x:Class="Wiper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2003/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2003/xaml"
        xmlns:vm="clr-namespace:Wiper.ViewModels"
        Title="Solution Cleaner V2.0" Height="600" Width="800"
        Background="#F5F5F5">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row= "0" Margin="0,0,0,20">
            <TextBlock Text="Solution Path (.sln)" FontWeight="Bold" Margin="0,0,0,5"/>
            <DockPanel>
                <Button Content="Sök efter bin/obj" Command="{Binding ScanCommand}" 
                        Padding="15,5" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                <TextBox Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Identifierade mappar" Margin="0,0,0,10">
            <ListView ItemsSource="{Binding Folders}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Rensa">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding Name}" Width="60"/>
                        <GridViewColumn Header="Sökväg" DisplayMemberBinding="{Binding FullPath}" Width="550"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Logg">
            <ListBox ItemsSource="{Binding Logs}" Background="#1E1E1E" Foreground="#85BB65" FontFamily="Consolas"/>
        </GroupBox>

        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem Content="{Binding StatusMessage}"/>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <Button Content="KÖR RENSNING &amp; STARTA OM VS" 
                        Command="{Binding CleanCommand}"
                        Background="#007ACC" Foreground="White" 
                        Padding="20,8" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Grid.RowSpan="4" Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="10"/>
                <TextBlock Text="Arbetar..." HorizontalAlignment="Center" Margin="10"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>