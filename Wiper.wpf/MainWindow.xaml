<Window x:Class="Wiper.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Wiper.WPF.ViewModels"
        xmlns:conv="clr-namespace:Wiper.WPF.Converters"
        Title="Wiper"
        Height="900" Width="700"
        MinHeight="650" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        AllowDrop="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:PipelineStepColorConverter x:Key="PipelineColor"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="1.8*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- RAD 0: Header -->
        <Border Grid.Row="0" Style="{DynamicResource SurfaceCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Lösningsfil (.sln / .slnx)" Style="{DynamicResource LabelStyle}"/>
                    <DockPanel>
                        <Button Content="Skanna" Command="{Binding ScanCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Style="{DynamicResource PrimaryButton}"
                                DockPanel.Dock="Right" Margin="8,0,0,0"/>
                        <Button Content="…" Click="BrowseForSolution"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Style="{DynamicResource SecondaryButton}"
                                DockPanel.Dock="Right" Margin="4,0,0,0" ToolTip="Bläddra efter .sln-fil"/>
                        <TextBox Text="{Binding Settings.SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource ModernTextBox}"/>
                    </DockPanel>
                    <TextBlock Text="Dra en .sln eller .slnx hit för att skanna direkt"
                               Foreground="{DynamicResource HintForeground}" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
                <!--<ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkMode}"
                              Command="{Binding ToggleThemeCommand}"
                              ToolTip="Byt ljust/mörkt tema"
                              Width="36" Height="36" VerticalAlignment="Top" Margin="12,0,0,0"
                              Background="Transparent" BorderThickness="1"
                              BorderBrush="{DynamicResource BorderMedium}" Cursor="Hand">
                    <TextBlock Text="🌙" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </ToggleButton>-->
            </Grid>
        </Border>

        <!-- RAD 1: Pipeline-indikator -->
        <Border Grid.Row="1" Style="{DynamicResource SurfaceCard}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                             Fill="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Scanning}"/>
                    <TextBlock Text="SCAN" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"
                               Foreground="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Scanning}"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="→" Foreground="{DynamicResource HintForeground}" VerticalAlignment="Center" Margin="6,0" FontSize="14"/>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                             Fill="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=LockCheck}"/>
                    <TextBlock Text="LOCK CHECK" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"
                               Foreground="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=LockCheck}"/>
                </StackPanel>
                <TextBlock Grid.Column="3" Text="→" Foreground="{DynamicResource HintForeground}" VerticalAlignment="Center" Margin="6,0" FontSize="14"/>
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                             Fill="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Cleaning}"/>
                    <TextBlock Text="CLEAN" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"
                               Foreground="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Cleaning}"/>
                </StackPanel>
                <TextBlock Grid.Column="5" Text="→" Foreground="{DynamicResource HintForeground}" VerticalAlignment="Center" Margin="6,0" FontSize="14"/>
                <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                             Fill="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Restarting}"/>
                    <TextBlock Text="RESTART" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"
                               Foreground="{Binding PipelineState, Converter={StaticResource PipelineColor}, ConverterParameter=Restarting}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RAD 2: Filter + dynamiska mappar -->
        <Border Grid.Row="2" Style="{DynamicResource SurfaceCard}" Padding="12,10">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="Inkludera:" Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ItemsControl ItemsSource="{Binding Settings.FolderTypeOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,0" Padding="8,4"
                                        BorderBrush="{DynamicResource BorderLight}"
                                        BorderThickness="1" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        <Button Content="✕" FontSize="10" Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Margin="5,0,0,0" Foreground="{DynamicResource HintForeground}"
                                                Command="{Binding DataContext.Settings.RemoveFolderCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
                <DockPanel Margin="0,8,0,0">
                    <Button Content="+ Mapp" Command="{Binding Settings.AddFolderCommand}"
                            Style="{DynamicResource SecondaryButton}" FontSize="11"
                            Padding="10,4" DockPanel.Dock="Right" Margin="6,0,0,0"/>
                    <TextBox Text="{Binding Settings.NewFolderName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBox}" FontSize="12" Height="28"
                             ToolTip="Mappnamn att lägga till (t.ex. node_modules)"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- RAD 3: Mapplista -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                CornerRadius="8" Background="{DynamicResource SurfaceBackground}" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Hittade mappar" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FolderList.Folders.Count, StringFormat='{}{0} st'}"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </DockPanel>
                </Border>
                <ListView Grid.Row="1" ItemsSource="{Binding FolderList.Folders}"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Projekt" DisplayMemberBinding="{Binding ProjectName}" Width="150"/>
                            <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding Name}" Width="70"/>
                            <GridViewColumn Header="Storlek" DisplayMemberBinding="{Binding SizeDisplay}" Width="80"/>
                            <GridViewColumn Header="Sökväg" DisplayMemberBinding="{Binding FullPath}" Width="300"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- RAD 4: GridSplitter -->
        <GridSplitter Grid.Row="4" Height="5" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

        <!-- RAD 5: Logg -->
        <Border Grid.Row="5" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                CornerRadius="8" Background="{DynamicResource LogBackground}" Margin="0,4,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="10,6" BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><TextBlock Text="LOGG" FontFamily="Consolas" FontSize="11" Foreground="#4ADE80"
                                   VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                        
                            <Button Content="Kopiera" Command="{Binding LogVM.CopyLogsCommand}"
                                    Background="Transparent" Foreground="#888" FontSize="11"
                                    BorderThickness="1" BorderBrush="#333" Padding="8,3" Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Content="Rensa" Command="{Binding LogVM.ClearLogsCommand}"
                                    Background="Transparent" Foreground="#888" FontSize="11"
                                    BorderThickness="1" BorderBrush="#333" Padding="8,3" Cursor="Hand"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding LogVM.Logs}"
                         Background="Transparent" Foreground="#4ADE80" FontFamily="Consolas"
                         FontSize="12" BorderThickness="0" Padding="10,6"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"/>
            </Grid>
        </Border>

        <!-- RAD 6: Statusbar -->
        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Status}"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Total vinst: " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                <TextBlock Text="{Binding FolderList.TotalSizeDisplay}"
                           Foreground="{DynamicResource AccentBlue}" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>
            <CheckBox Grid.Column="2" Content="Simulera (Dry Run)" IsChecked="{Binding IsDryRun}"
                      Foreground="{DynamicResource TextSecondary}" FontSize="12"
                      VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Grid.Column="3" Content="Avbryt" Command="{Binding CancelOperationCommand}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Grid.Column="4" Content="KÖR RENSNING" Command="{Binding CleanCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    Style="{DynamicResource PrimaryButton}" Padding="22,9" FontSize="13"/>
        </Grid>

        <!-- Laddning-overlay -->
        <Grid Grid.RowSpan="7" Background="#88000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="{DynamicResource SurfaceBackground}" CornerRadius="10" Padding="30,20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderMedium}" BorderThickness="1">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="4" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource TextPrimary}"
                               FontSize="13" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
