<Window x:Class="Wiper.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Wiper.wpf.ViewModels"
        xmlns:conv="clr-namespace:Wiper.wpf.Converters"
        Title="Wiper V2.0" Height="600" Width="800" Background="#F0F0F0">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15" Background="White">
            <Image Source="Resources/Images/wiper-logo.png"
                Width="120"
                Height="120"/>
            <TextBlock Text="Solution Path (.sln)" FontWeight="Bold" Margin="0,0,0,5"/>
            <DockPanel>
                <Button Content="Skanna mappar" Command="{Binding ScanCommand}" 
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Padding="15,5" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                <TextBox Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
            </DockPanel>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Mappar hittade">
            <ListView ItemsSource="{Binding Folders}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Val">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding Name}" Width="60"/>
                        <GridViewColumn Header="Sökväg" DisplayMemberBinding="{Binding FullPath}" Width="500"/>
                        <GridViewColumn Header="Storlek" DisplayMemberBinding="{Binding SizeDisplay}" Width="80"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <ListBox Grid.Row="2" ItemsSource="{Binding Logs}" Margin="0,10,0,0" 
                 Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas"/>

        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <CheckBox Content="Dry Run (Simulera)" 
                  IsChecked="{Binding IsDryRun}" 
                  VerticalAlignment="Center" 
                  Margin="10,0"/>
            </StackPanel>

            <Button Content="KÖR RENSNING" HorizontalAlignment="Right"
            Command="{Binding CleanCommand}" 
            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
            Background="#007ACC" Foreground="White" FontWeight="Bold" Padding="20,5"/>
        </StatusBar>

        <Grid Grid.RowSpan="4" Background="#88FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
        </Grid>


        <StackPanel Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Inkludera: " VerticalAlignment="Center" FontWeight="Bold"/>
            <ItemsControl ItemsSource="{Binding FolderTypeOptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" Margin="10,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <GridView>
            <GridViewColumn Header="Val">
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>
            <GridViewColumn Header="Typ" DisplayMemberBinding="{Binding Name}" Width="60"/>
            <GridViewColumn Header="Storlek" DisplayMemberBinding="{Binding SizeDisplay}" Width="80"/>
            <GridViewColumn Header="Sökväg" DisplayMemberBinding="{Binding FullPath}" Width="400"/>
        </GridView>

        <StatusBarItem HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total vinst: " FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalSizeDisplay}" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,10,0"/>
            </StackPanel>
        </StatusBarItem>

    </Grid>
</Window>